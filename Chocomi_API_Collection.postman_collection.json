              "host": ["localhost"],
              "port": "8000",
              "path": ["ws", "chat"],
              "query": [
                {
                  "key": "user_id",
                  "value": "user-001"
                }
              ]
            },
            "description": "WebSocket endpoint for real-time chat. Connect and send JSON messages:\n{\n  \"type\": \"chat\",\n  \"message\": \"What GPUs do you have under $600?\",\n  \"user_id\": \"user-001\"\n}\n\nExpects streaming responses with tokens."
          },
          "response": []
