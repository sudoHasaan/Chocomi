          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"field\": \"preferences\",\n  \"value\": {\"gpu_preference\": \"RTX 4090\", \"processor_preference\": \"AMD Ryzen 9 7950X3D\"}\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/crm/user/user-001",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "crm", "user", "user-001"]
            },
            "description": "Update a specific field for an existing user"
          },
          "response": []
        }
